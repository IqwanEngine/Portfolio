# =========================================================================
# IQWANENGINE CORE // REPOSITORY BLOCKLIST SYSTEM (.gitignore)
# =========================================================================

# 1. Dependency Bloat Filters (Package Managers)
node_modules/
jspm_packages/
web_modules/
.npm
.eslintcache

# 2. Production & Build Artifacts (Compiled Outputs)
dist/
build/
out/
.next/
.vite/
.vercel/

# 3. Test Coverage & Reporting
coverage/
*.lcov
.nyc_output

# 4. Operating System Junk & Editor Pollution
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
.zed/
*.tmp
*.swp

# 5. System Logs & Execution Core Diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 6. SECURE CONSTELLATIONS (Strict Environment Token Locks)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 7. Safe Exceptions (Allow Blueprint Configurations)
!.env.example
